<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== OPERACIÓN CUANDO SE PRESIONA ===== -->

    <item android:state_pressed="true">

        <shape android:shape="rectangle">

            <!-- Color al tocar el botón -->
            <solid android:color="@color/rojo_principal" />

            <!-- Esquinas más redondeadas -->
            <corners android:radius="18dp" />

            <!-- Borde externo del botón -->
            <stroke
                android:width="2dp"
                android:color="@color/rojo_oscuro" />

        </shape>

    </item>


    <!-- ===== OPERACIÓN EN ESTADO NORMAL ===== -->

    <item>

        <shape android:shape="rectangle">

            <!-- Degradado diagonal -->
            <gradient
                android:angle="45"
                android:startColor="@color/rojo_principal"
                android:endColor="@color/vinotinto" />

            <!-- Esquinas redondeadas -->
            <corners android:radius="18dp" />

            <!-- Borde del botón -->
            <stroke
                android:width="1dp"
                android:color="@color/rojo_oscuro" />

        </shape>

    </item>

</selector>